# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# On the server, keep it owned by the service user with mode 600.

# --- Database (required) ---
# PostgreSQL connection string. The app fails fast at startup if this is unset
# or is not a PostgreSQL URL. Managed hosts usually also need ?sslmode=require.
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg://lol_predictor_user:REPLACE_ME@localhost:5432/lol_predictor

# --- Environment ---
# development | production
APP_ENV=development

# --- Tests only (optional) ---
# Integration tests are skipped unless this is set. Point it at a STAGING
# database: the test fixtures truncate participant tables between tests.
# TEST_DATABASE_URL=postgresql+psycopg://lol_predictor_staging_user:REPLACE_ME@localhost:5432/lol_predictor_staging

# NOTE: there is deliberately no API base URL or CORS origin setting. Nginx
# serves the frontend and proxies /api to uvicorn on the same origin, so the
# browser calls relative paths and no CORS configuration is required.
